APP_NAME=CuentaClara
APP_VERSION=1.0.0
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev uses SQLite (zero setup). PRODUCTION must use managed Postgres so
# data survives deploys — set these on Render (DB_CONNECTION=pgsql + the creds
# from the Render Postgres instance, or a single DB_URL connection string):
#   DB_CONNECTION=pgsql
#   DB_URL=postgres://user:pass@host:5432/dbname   (or the DB_* vars below)
#   DB_HOST=... DB_PORT=5432 DB_DATABASE=... DB_USERNAME=... DB_PASSWORD=...
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Receipt images live on RECEIPTS_DISK (see below). In production set it to s3
# so uploads survive deploys; these AWS creds + a PRIVATE bucket are required.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- CuentaClara ---------------------------------------------------------

# Default admin, created (idempotently) on container start (entrypoint).
# Handy for the first deploy / fresh database. Leave blank to skip and use
# `php artisan admin:make` instead.
ADMIN_EMAIL=admin@cuentaclara.test
ADMIN_PASSWORD=changeme-please
ADMIN_NAME=Admin

# Where receipt images are stored. Receipts are financial PII: served through
# the app (never a public URL), so any option below stays private.
#   'local'      → dev only; lives in the container, wiped on every deploy.
#   'persistent' → production on Render: a Persistent Disk that survives
#                  deploys/restarts. Also set RECEIPTS_DISK_ROOT (below).
#   's3'         → production on a private S3 bucket (needs the AWS_* vars).
RECEIPTS_DISK=local

# Only for RECEIPTS_DISK=persistent: absolute path on the mounted Render disk.
# The Render disk must be mounted at (or above) this path. Example:
#   RECEIPTS_DISK_ROOT=/var/data/receipts   (disk mounted at /var/data)
# RECEIPTS_DISK_ROOT=

# Receipt reading: 'ocr' (Tesseract, prod default), 'fake' (dev), 'anthropic'.
AI_DRIVER=fake

# Payment review: 'manual' (organizer confirms every payment) or 'auto'.
REVIEW_MODE=manual
